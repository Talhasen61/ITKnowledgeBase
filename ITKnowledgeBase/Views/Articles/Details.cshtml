@model ITKnowledgeBase.Models.Article

@{
    ViewData["Title"] = "Makale Detayı";
}

<h1>Makale Detayı</h1>

<div class="card shadow">

    <div class="card-header">
        <h3>@Model.Title</h3>
    </div>

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">
                Kategori
            </dt>

            <dd class="col-sm-9">
                @Model.Category?.Name
            </dd>

            <dt class="col-sm-3">
                Oluşturulma Tarihi
            </dt>

            <dd class="col-sm-9">
                @Model.CreatedDate.ToString("dd.MM.yyyy")
            </dd>

            <dt class="col-sm-3">
                İçerik
            </dt>

            <dd class="col-sm-9">
                <p>@Model.Content</p>
            </dd>

        </dl>

    </div>

    <<div class="card-footer d-flex gap-2">

        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-warning">
            ✏️ Düzenle
        </a>

        <a asp-action="Index"
           class="btn btn-secondary">
            ← Listeye Dön
        </a>
      
    </div>

</div>